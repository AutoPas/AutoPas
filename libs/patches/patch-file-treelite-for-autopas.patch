+++ b/treelite/cmake/ExternalLibs.cmake
@@ -1,4 +1,17 @@
 include(FetchContent)
+set(TREELITE_LOCAL_DEPS_DIR "" CACHE PATH
+    "Directory containing offline dependency archives (rapidjson, nlohmann_json, mdspan)")
+
+function(_treelite_require_local_archive out_var filename)
+  if(NOT TREELITE_LOCAL_DEPS_DIR)
+    message(FATAL_ERROR "TREELITE_LOCAL_DEPS_DIR is not set")
+  endif()
+  set(_path "${TREELITE_LOCAL_DEPS_DIR}/${filename}")
+  if(NOT EXISTS "${_path}")
+    message(FATAL_ERROR "Required local archive not found: ${_path}")
+  endif()
+  set(${out_var} "${_path}" PARENT_SCOPE)
+endfunction()
 
