box-min                          :  [0, 0, 0]
box-max                          :  [20, 20, 20]
cell-size                        :  [0.5]
deltaT                           :  0
pause-simulation-during-tuning   :  false
sorting-threshold                :  8
iterations                       :  100
boundary-type                    :  [none, none, none]
