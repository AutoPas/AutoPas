# Running single-site MD simulation.

container                        :  [HierarchicalGrid]
verlet-rebuild-frequency         :  10
verlet-skin-radius               :  0.1
tuning-strategies                :  []
tuning-metric                    :  time
tuning-interval                  :  5000
tuning-samples                   :  3
early-stopping-factor            :  inf
use-LOESS-smoothening            :  false
PairwiseInteraction:             
  functor                        :  Lennard-Jones (12-6) AVX intrinsics
  traversal                      :  [hgrid_block4]
  data-layout                    :  [SoA]
  newton3                        :  [enabled]
cutoff                           :  2.4
cutoffs                          :  [0.24, 2.4]
box-min                          :  [0, 0, 0]
box-max                          :  [20, 20, 20]
cell-size                        :  [0.5]
deltaT                           :  0
pause-simulation-during-tuning   :  false
sorting-threshold                :  8
iterations                       :  100
boundary-type                    :  [none, none, none]
Sites:                           
  0:
    epsilon                      :  1
    sigma                        :  0.08
    nu                           :  0
    mass                         :  1
  1:
    epsilon                      :  1
    sigma                        :  0.8
    nu                           :  0
    mass                         :  1
Objects:                         
  CubeUniform:
    0:  
      numberOfParticles          :  500000
      box-length                 :  [20, 20, 20]
      bottomLeftCorner           :  [0, 0, 0]
      velocity                   :  [0, 0, 0]
      particle-type-id           :  0
  CubeUniform:
    1:  
      numberOfParticles          :  500000
      box-length                 :  [20, 20, 20]
      bottomLeftCorner           :  [0, 0, 0]
      velocity                   :  [0, 0, 0]
      particle-type-id           :  1
use-tuning-logger                :  false
output-suffix                    :  
log-level                        :  info
no-end-config                    :  false
no-progress-bar                  :  true
load-balancer                    :  InvertedPressure
load-balancing-interval          :  100
subdivide-dimension              :  [true, true, true]
energy-sensor                    :  rapl


