container                        :  [LinkedCells]
verlet-rebuild-frequency         :  10
verlet-skin-radius               :  0.1
tuning-strategies                :  []
tuning-metric                    :  time
tuning-interval                  :  5000
tuning-samples                   :  3
early-stopping-factor            :  inf
use-LOESS-smoothening            :  false
PairwiseInteraction:             
  functor                        :  Lennard-Jones (12-6) AVX intrinsics
  traversal                      :  [lc_c08]
  data-layout                    :  [SoA]
  newton3                        :  [enabled]
cutoff                           :  2.4
cutoffs                          :  [0.72, 2.4]
box-min                          :  [0, 0, 0]
box-max                          :  [20, 20, 20]
cell-size                        :  [0.5]
deltaT                           :  0
pause-simulation-during-tuning   :  false
sorting-threshold                :  8
iterations                       :  100
boundary-type                    :  [none, none, none]
Sites:                           
  0:
